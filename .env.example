# Formspree form endpoint (https://formspree.io → create a form → copy endpoint)
# Example: https://formspree.io/f/xpwqapjn
VITE_FORMSPREE_ENDPOINT=

# Microsoft Clarity project ID (optional override; default in code: xjvfg8abh3)
# VITE_CLARITY_PROJECT_ID=xjvfg8abh3

# Google Analytics 4 Measurement ID (Admin → Data streams → Web → Measurement ID)
# Example: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=
